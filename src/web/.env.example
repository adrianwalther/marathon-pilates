# Marathon Pilates — required environment variables.
# Copy to .env.local for local dev; set the same keys in Vercel (Production) for
# deploys. instrumentation.ts logs any missing ones loudly at server boot.
# (Names only — never commit real secrets.)

# --- Core (Supabase) — app is non-functional without these ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # sb_publishable_... (new key format only)
SUPABASE_SERVICE_ROLE_KEY=           # sb_secret_...      (new key format only)

# --- Payments (Stripe, LIVE mode) — checkout/memberships/gift cards/webhook ---
STRIPE_SECRET_KEY=                   # sk_live_...
STRIPE_WEBHOOK_SECRET=               # whsec_... (from the Stripe webhook endpoint)

# --- Rate limiting (Upstash Redis) — AI routes FAIL CLOSED in prod if unset ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- AI providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# --- Email (Resend) — booking emails are dry-run (logged) until set ---
RESEND_API_KEY=
EMAIL_FROM=

# --- App ---
NEXT_PUBLIC_APP_URL=https://marathon-pilates.vercel.app
BETA_PASSWORD=                       # beta gate; if unset, gate is effectively open
